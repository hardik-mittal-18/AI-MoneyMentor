OPENAI_API_KEY=your_api_key_here

# ------------------------------
# Auth (JWT)
# ------------------------------
# Required when using /auth/* and protected APIs.
# Generate a long random value (32+ chars).
JWT_SECRET=change-me-to-a-long-random-secret

# Access token lifetime (seconds). Default is 3600.
# JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# ------------------------------
# CORS
# ------------------------------
# Comma-separated list of trusted frontend origins.
# Example: CORS_ALLOW_ORIGINS=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173

# ------------------------------
# Supabase PostgreSQL (optional)
# ------------------------------
# When set, the backend persists Users, Broker Balance, Portfolio, SIP Plans,
# Transactions and Audit Logs in Postgres via SQLAlchemy.
#
# Supabase connection strings look like:
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#
# If you have trouble connecting, add SSL mode:
# DATABASE_URL=postgresql://.../postgres?sslmode=require
#
# If DATABASE_URL is not set, the API runs in demo (in-memory) mode.
# DATABASE_URL=

# Demo-friendly option: local SQLite (still a real DB)
# DATABASE_URL=sqlite:///./demo.db

# Optional pool tuning
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ------------------------------
# Demo Payment Gateway (OTP SMTP)
# ------------------------------
# By default, if SMTP is not configured, the backend can simulate delivery and the UI can show the OTP.
# To require real Gmail/Outlook delivery (no simulation), set OTP_REQUIRE_SMTP=true.
#
# Gmail (requires an App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USERNAME=your-gmail@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-gmail@gmail.com
#
# Outlook / Microsoft 365 (may require SMTP AUTH enabled):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USERNAME=your-email@outlook.com
# SMTP_PASSWORD=your-password-or-app-password
# SMTP_FROM=your-email@outlook.com

# OTP expiry (clamped between 120 and 300 seconds)
# DEMO_OTP_TTL_SECONDS=180

# If true, OTP must be delivered via SMTP (no simulated delivery, no demo_otp)
# OTP_REQUIRE_SMTP=true

# Force echoing OTP in API response (demo/testing only)
# DEMO_RETURN_OTP=true
